# Frontend Environment Variables

# Development API URL (used with `npm run dev`)
# Leave empty to use localhost:8001
VITE_API_BASE_URL=http://localhost:8001

# Production API URL (set this in Vercel dashboard)
# Example: https://your-username-ai-wikipedia-rag.hf.space
# This will be set as VITE_API_BASE_URL environment variable in Vercel
